{
  "name": "barktown-ingest",
  "version": "0.1.0",
  "private": true,
  "description": "Pi-side ingest service for barktown — watches MinIO /new/, validates filenames, generates waveforms, organises audio, updates index.json",
  "type": "module",
  "scripts": {
    "start": "node ingest-service.mjs",
    "restart": "sudo systemctl restart barktown-ingest",
    "validate-index": "node validate-index.mjs",
    "rebuild-index": "node rebuild-index.mjs",
    "compare-index-with-list": "node compare-index-with-list.mjs",
    "check-sizes": "node check-sizes.mjs",
    "observe": "journalctl -u barktown-ingest -f"
  },
  "dependencies": {
    "minio": "^8.0.7"
  },
  "engines": {
    "node": ">=18"
  }
}
